# Copy to config.env and edit before running install.sh:
#   cp deploy/config.env.example deploy/config.env
#
# Wrap values in single quotes if they contain spaces or special characters.

CONTROL_PANEL=hestiacp
SITE_USER=cvmso
HESTIA_USER=cvmso
DOMAIN=scrape.cvmso.com

# Must NOT be 3000 (OpsBoard) or 3001 (OmniDesk)
API_PORT=3010

APP_DIR=/home/cvmso/apps/scrapeboard

# Bootstrap admin (first boot). Change password + 2FA on first login.
# Prefer a password WITHOUT # or wrap carefully — install quotes .env values,
# but # in an unquoted .env line truncates the password.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@cvmso.com
BOOTSTRAP_ADMIN_PASSWORD='ChangeMeNow-strong!'

# Optional — auto-generated with openssl if empty
SECRET_KEY=

# Git repo to clone on the VPS (optional — or rsync files into APP_DIR)
REPO_URL=https://github.com/x-o-r-r-o/scrapeboard.git
