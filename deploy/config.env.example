# Copy to config.env and edit before running install.sh:
#   cp deploy/config.env.example deploy/config.env
#
# Wrap values in single quotes if they contain spaces or special characters.

CONTROL_PANEL=hestiacp
SITE_USER=cvmso
HESTIA_USER=cvmso
DOMAIN=scrape.cvmso.com

# Must NOT be 3000 (OpsBoard) or 3001 (OmniDesk)
API_PORT=3010

APP_DIR=/home/cvmso/apps/scrapeboard

# Prefer a password WITHOUT # when possible. Always wrap in single quotes here.
# The installer permanently writes double-quoted values into panel/backend/.env
# so characters like # & [ ] are preserved.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@cvmso.com
BOOTSTRAP_ADMIN_PASSWORD='ChangeMeNow-strong!'

# Optional — auto-generated with openssl if empty
SECRET_KEY=

# Git repo to clone on the VPS (optional — or rsync files into APP_DIR).
# Panel install/update uses git sparse-checkout to exclude worker/ (scrape agents
# run on separate machines; copy/install worker/ only on those hosts).
REPO_URL=https://github.com/x-o-r-r-o/scrapeboard.git

# Daily panel auto-update (systemd timer): check git → pull + pip + build + restart.
# Set AUTO_UPDATE_ENABLED=0 to disable. Hour is server local time (0–23).
AUTO_UPDATE_ENABLED=1
AUTO_UPDATE_HOUR=4
AUTO_UPDATE_MINUTE=0
