# Scrapeboard — git ignore
#
# Local full-repo clones keep worker/ for development. Production panel
# deploys (deploy/hestiacp) use sparse-checkout / post-sync removal so
# worker/ is never installed on the control-panel host.

.DS_Store
.env
.env.*
!.env.example
deploy/config.env
**/__pycache__/
**/*.pyc
**/.venv/
**/node_modules/
**/dist/
panel/data/
**/*.db
**/*.db-*
worker/logs/
worker/work/
worker/run_service.cmd
worker/results/
worker/test_out/
worker/test_results.csv
worker/.setup_*_done
.idea/
.vscode/
*.log
.coverage
htmlcov/
