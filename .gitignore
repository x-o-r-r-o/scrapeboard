# Scrapeboard — git ignore
#
# Local full-repo clones may keep panel/ + worker/ for development.
# Production hosts persist machine role in .scrapeboard-role (panel|worker)
# and use role-based sparse-checkout:
#   panel  → exclude worker/
#   worker → exclude panel/ and deploy/

.DS_Store
.env
.env.*
!.env.example
.scrapeboard-role
deploy/config.env
**/__pycache__/
**/*.pyc
**/.venv/
**/node_modules/
**/dist/
panel/data/
**/*.db
**/*.db-*
worker/logs/
worker/work/
worker/run_service.cmd
worker/results/
worker/test_out/
worker/test_results.csv
worker/.setup_*_done
.idea/
.vscode/
*.log
.coverage
htmlcov/
